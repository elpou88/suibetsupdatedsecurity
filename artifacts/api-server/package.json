{
  "name": "@workspace/api-server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "export NODE_ENV=development && pnpm run build && pnpm run start",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "node ./build-test.mjs && node --enable-source-maps ./dist/test-e2e-p2p.mjs",
    "test:fix": "node ./build-test.mjs && node --enable-source-maps ./dist/test-fix-verification.mjs",
    "test:reclaim": "node ./build-test.mjs && node --enable-source-maps ./dist/test-reclaim.mjs",
    "sweep-stuck": "node ./build-test.mjs && node --enable-source-maps ./dist/sweep-stuck-offers.mjs",
    "onchain-sweep": "node ./build-test.mjs && node --enable-source-maps ./dist/onchain-sweep.mjs",
    "upgrade-warp": "node scripts/upgrade-warp.mjs",
    "test:warp": "node scripts/test-warp-onchain.mjs",
    "test:engines": "node ./build-test.mjs && node --enable-source-maps ./dist/test-engines-onchain.mjs"
  },
  "dependencies": {
    "@mysten/bcs": "^2.0.3",
    "@mysten/deepbook-v3": "^1.4.1",
    "@mysten/sui": "^2.13.4",
    "@mysten/zklogin": "^0.8.1",
    "axios": "^1.17.0",
    "connect-pg-simple": "^9.0.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2",
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.7.0",
    "express": "^5",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "openai": "^4.100.0",
    "pg": "^8.16.0",
    "pino": "^9",
    "pino-http": "^10",
    "postgres": "^3.4.7",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.14",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.9",
    "esbuild": "^0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "pino-pretty": "^13",
    "thread-stream": "3.1.0"
  }
}
